{
  "manifest_version": 3,
  "name": "JobHuntOS",
  "version": "1.0.0",
  "description": "AI-powered job analysis: fit score, resume bullets, outreach message, saved to Notion.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.jobvite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Analyze this job with JobHuntOS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js", "setup.html", "setup.css", "setup.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
